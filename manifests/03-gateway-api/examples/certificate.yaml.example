# =============================================================================
# Certificate managed by cert-manager (OPTIONAL)
# =============================================================================
# If you use cert-manager (recommended), create the Certificate in the same
# namespace as the Gateway. cert-manager 1.14+ understands Gateway API and
# issues/renews the Secret referenced by the Gateway.
#
# Requires a pre-created ClusterIssuer (e.g. letsencrypt-prod with HTTP-01 or
# DNS-01 challenge).
#
# If you do NOT use cert-manager, leave this file out of the kustomize/apply
# and manually copy the Secret to the gateway-system namespace.
# =============================================================================
apiVersion: cert-manager.io/v1
kind: Certificate
metadata:
  name: shop-tls
  namespace: gateway-system
  labels:
    app.kubernetes.io/part-of: boutique
    app.kubernetes.io/managed-by: ingress-to-gateway-demo
spec:
  # Resulting Secret. The Gateway references it in listeners[].tls.certificateRefs
  secretName: shop-tls

  # Auto-renew 30 days before expiration
  renewBefore: 720h  # 30 days

  # Standard Let's Encrypt duration = 90 days
  duration: 2160h    # 90 days

  dnsNames:
    - shop.example.com

  # Pre-existing ClusterIssuer. Adjust the name to yours.
  issuerRef:
    name: letsencrypt-prod
    kind: ClusterIssuer
    group: cert-manager.io
