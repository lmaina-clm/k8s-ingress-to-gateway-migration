# =============================================================================
# TLS Secret for the Ingress
# =============================================================================
# This is a PLACEHOLDER with a self-signed certificate for shop.example.com.
# For production, replace with your real certificate or use cert-manager.
#
# To generate a self-signed cert:
#
#   openssl req -x509 -nodes -days 365 -newkey rsa:2048 \
#     -keyout shop.key -out shop.crt \
#     -subj "/CN=shop.example.com/O=demo" \
#     -addext "subjectAltName=DNS:shop.example.com"
#   kubectl create secret tls shop-tls \
#     -n microservices --cert=shop.crt --key=shop.key \
#     --dry-run=client -o yaml > tls-secret.yaml
#
# Once in production, this Secret should be managed via cert-manager or
# external-secrets (do NOT commit real certificates to the repo).
# =============================================================================
apiVersion: v1
kind: Secret
metadata:
  name: shop-tls
  namespace: microservices
  labels:
    app.kubernetes.io/managed-by: ingress-to-gateway-demo
type: kubernetes.io/tls
data:
  # REPLACE: these are base64 placeholders for a self-signed cert.
  # Generate a real one with the openssl command above before applying.
  tls.crt: PEM_BASE64_HERE
  tls.key: PEM_BASE64_HERE
