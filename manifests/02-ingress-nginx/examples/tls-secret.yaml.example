# =============================================================================
# TLS Secret para el Ingress
# =============================================================================
# Este es un PLACEHOLDER con un certificado self-signed para shop.example.com.
# Para producción, sustitúyelo con tu certificado real o usa cert-manager.
#
# Para generar un cert self-signed:
#
#   openssl req -x509 -nodes -days 365 -newkey rsa:2048 \
#     -keyout shop.key -out shop.crt \
#     -subj "/CN=shop.example.com/O=demo" \
#     -addext "subjectAltName=DNS:shop.example.com"
#   kubectl create secret tls shop-tls \
#     -n microservices --cert=shop.crt --key=shop.key \
#     --dry-run=client -o yaml > tls-secret.yaml
#
# Una vez en producción, este Secret debe gestionarse vía cert-manager o
# external-secrets (NO commitear certificados reales al repo).
# =============================================================================
apiVersion: v1
kind: Secret
metadata:
  name: shop-tls
  namespace: microservices
  labels:
    app.kubernetes.io/managed-by: ingress-to-gateway-demo
type: kubernetes.io/tls
data:
  # CAMBIAR: estos son placeholders base64 de un cert self-signed.
  # Generar uno real con el comando openssl de arriba antes de aplicar.
  tls.crt: PEM_BASE64_HERE
  tls.key: PEM_BASE64_HERE
