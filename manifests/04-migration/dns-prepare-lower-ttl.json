{
  "Comment": "Lower TTL on shop.example.com to 60s for fast propagation during migration. Apply 24h before the first canary step.",
  "Changes": [
    {
      "Action": "UPSERT",
      "ResourceRecordSet": {
        "Name": "shop.example.com.",
        "Type": "A",
        "SetIdentifier": "ingress-nginx-primary",
        "Weight": 100,
        "AliasTarget": {
          "HostedZoneId": "<INGRESS_NLB_ZONE_ID>",
          "DNSName": "<INGRESS_NLB_HOSTNAME>",
          "EvaluateTargetHealth": true
        }
      }
    }
  ]
}
